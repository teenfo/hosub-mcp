# --- 키움 REST API ---
# mock = 모의투자(mockapi.kiwoom.com), real = 실전(api.kiwoom.com)
KIWOOM_ENV=mock
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
# 주문 계좌번호 (모의투자 계좌부터!)
KIWOOM_ACCOUNT=

# --- 대시보드 ---
DASH_PASSWORD=change-me
SESSION_SECRET=change-me-too

# --- 데이터 ---
# 홈서버에서는 /data/trading 권장 (1.8TB 디스크)
DATA_DIR=./data
