# hosub-mcp 리버스 프록시 (Caddy)
#
# 공인 HTTPS 노출 + 자동 TLS. Caddy 가 Let's Encrypt/ZeroSSL 에서 인증서를
# 자동 발급·갱신하고, 내부의 평문 uvicorn(127.0.0.1:8700)으로 프록시한다.
#
# ⚠️ iptime DDNS(*.iptime.org) 는 사용할 수 없다.
#    iptime 이 도메인 전체에 CAA 레코드(CAA 0 issue ";")를 걸어 모든 CA 의
#    인증서 발급을 차단하기 때문이다(사용자가 못 바꿈). 대신 같은 집 IP를
#    가리키는 DuckDNS 서브도메인을 쓴다. → docs/SETUP.md 부록 B 참고.
#
# 설치:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   # 아래 hosub.duckdns.org 를 본인 DuckDNS 서브도메인으로 교체
#   sudo systemctl restart caddy
#
# 전제:
#   - iptime 공유기에서 외부 80, 443 → 192.168.0.3(서버)로 포트포워딩
#   - hosub.duckdns.org 가 집 공인 IP를 가리킴 (duckdns-update.timer 로 자동 갱신)

hosub.duckdns.org {
	# 대시보드(웹 UI·트레이딩 프록시)는 :8701(hosub-dash.service),
	# 그 외(/mcp, OAuth /authorize·/token·/register·/.well-known)는
	# :8700(hosub-mcp.service). 프로세스를 분리해 대시보드 배포·재시작이
	# MCP 세션을 끊지 않는다.
	@dash path / /login /logout /favicon.ico /api/* /static/*
	handle @dash {
		reverse_proxy 127.0.0.1:8701
	}
	handle {
		reverse_proxy 127.0.0.1:8700
	}

	# 인증서 발급 알림용 이메일(선택, 권장). 본인 이메일로 교체.
	# tls your-email@example.com

	# 접근 로그(선택)
	log {
		output file /var/log/caddy/hosub-mcp.log
		format console
	}

	# 참고: MCP는 Bearer 토큰으로, 대시보드는 세션 로그인으로 이미 보호된다.
	# 추가로 특정 IP만 허용하려면 아래 주석을 참고해 조정한다.
	# @blocked not remote_ip 1.2.3.4 5.6.7.0/24
	# respond @blocked "forbidden" 403
}
