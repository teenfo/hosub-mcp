# hosub MCP 서버 환경변수 템플릿
# 실제 값은 .env 로 복사해서 채우고, .env 는 절대 커밋하지 않는다.

# --- MCP 인증 ---
# claude.ai 커넥터는 OAuth 2.1 흐름으로 연결한다(대시보드 비밀번호로 승인).
# 아래 정적 토큰은 curl 테스트·비상용으로 병행 유지된다.
# 최소 32자 이상의 무작위 문자열 (예: openssl rand -hex 32)
HOSUB_MCP_TOKEN=

# --- 공개 URL (OAuth 메타데이터용) ---
# 커넥터로 노출할 때 이 값을 설정한다. OAuth .well-known 메타데이터의 issuer/
# endpoint 가 이 URL로 발급된다. 비우면 요청 헤더(X-Forwarded-*)에서 유추.
# 예: HOSUB_PUBLIC_URL=https://hosub.duckdns.org
HOSUB_PUBLIC_URL=

# --- OAuth 토큰 저장 DB (선택) ---
HOSUB_OAUTH_DB=data/oauth.db

# --- 대시보드 페이지 (선택) ---
# 데일리 브리핑 디렉터리. Claude 가 MCP write_file 로 날짜별 파일
# (예: html/morning-brief/2026-07-23.html)을 쓰면 대시보드 "데일리 브리핑"
# 페이지가 최신 것을 표시하고, 과거 날짜는 드롭다운으로 볼 수 있다.
HOSUB_BRIEFING_DIR=html/morning-brief
# 날씨 페이지 위치("위도,경도", 기본 서울) + 표시 라벨. Open-Meteo 무료 API 사용.
HOSUB_WEATHER_LATLON=37.5665,126.9780
HOSUB_WEATHER_LABEL=서울

# --- 감사 로그 DB 경로 (선택, 기본 data/audit.db) ---
HOSUB_MCP_DB=data/audit.db

# --- 레지스트리 경로 (선택, 기본 config/registry.yaml) ---
HOSUB_MCP_REGISTRY=config/registry.yaml

# --- 레지스트리 엄격 모드 (선택, 기본 false) ---
# true 이면 스크립트 경로 존재/실행권한까지 검증 (실서버용).
HOSUB_MCP_STRICT=false

# --- 대시보드 ---
# 대시보드 웹 로그인 비밀번호
HOSUB_DASH_PASSWORD=
# 세션 쿠키 서명 키 (예: openssl rand -hex 32). 비우면 기동 거부.
HOSUB_SESSION_SECRET=

# --- 바인딩 (선택) ---
HOSUB_MCP_HOST=127.0.0.1
HOSUB_MCP_PORT=8700

# --- 자동 업데이트 (선택) ---
# hosub-mcp-update.timer 가 추적할 브랜치 (기본 main).
# 이 브랜치에 새 커밋이 올라오면 5분 내 자동으로 pull + 재시작된다.
HOSUB_MCP_BRANCH=main

# --- DNS 리바인딩 보호 (선택) ---
# 설정 시 해당 Host/Origin 만 허용. 비우면 보호 비활성(Bearer+OAuth+Caddy TLS 의존).
# ⚠️ Claude 커넥터를 쓰면 반드시 비워두세요.
#    설정하면 MCP SDK 의 DNS 리바인딩 보호가 Claude 커넥터의 Origin(https://claude.ai)을
#    403 "Invalid Origin header" 로 거부해, "인증됐지만 서버 접근 불가" 로 연결이 실패합니다.
#    /mcp 는 Bearer/OAuth 토큰으로 이미 보호되므로(쿠키가 아니라 DNS 리바인딩 무관) 비워도 안전.
HOSUB_ALLOWED_HOSTS=

# --- DuckDNS (공인 노출용, 선택) ---
# iptime.org 는 CAA 로 인증서 발급이 막혀 있어(CAA 0 issue ";"), 같은 집 IP를
# 가리키는 DuckDNS 서브도메인으로 HTTPS 인증서를 발급받는다. https://duckdns.org
# duckdns-update.timer 가 이 값으로 집 공인 IP를 주기적으로 갱신한다.
DUCKDNS_DOMAIN=          # 서브도메인만 (예: hosub → hosub.duckdns.org)
DUCKDNS_TOKEN=           # DuckDNS 토큰 (⚠️ 비밀 — 절대 커밋 금지)
